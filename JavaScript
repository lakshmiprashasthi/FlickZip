let bookingData = {}, selectedDate = null, selectedTime = null, selectedSeats = [];

function openBooking(movie) {
  bookingData = typeof movie === 'string' ? JSON.parse(movie.replace(/'/g,'"')) : {...movie};
  selectedDate = null; selectedTime = null; selectedSeats = [];

  document.getElementById('modalHeader').innerHTML = `
    <div class="modal-poster" style="background:${genreBg[bookingData.genre]||'rgba(255,255,255,0.05)'}">${bookingData.emoji}</div>
    <div>
      <div class="modal-movie-title">${bookingData.title}</div>
      <div class="modal-movie-sub">${bookingData.genre} · ⭐ ${bookingData.rating||'—'} · ₹${bookingData.price}/seat</div>
    </div>`;

  const days=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  const months=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const today = new Date();
  document.getElementById('dateGrid').innerHTML = Array.from({length:7},(_,i)=>{
    const d=new Date(today); d.setDate(d.getDate()+i);
    return `<div class="date-chip" onclick="selectDate(this,'${d.getDate()} ${months[d.getMonth()]}')">
      <div class="date-chip-day">${i===0?'Today':days[d.getDay()]}</div>
      <div class="date-chip-num">${d.getDate()}</div>
    </div>`;
  }).join('');

  document.querySelectorAll('.time-chip').forEach(c=>c.classList.remove('selected'));
  document.getElementById('step1Btn').disabled = true;

  // reset modal state
  document.getElementById('progressDots').style.display = 'flex';
  document.getElementById('modalHeader').style.display = 'flex';
  document.getElementById('stepSuccess').classList.remove('active');
  goToStep(1, true);
  document.getElementById('modalBackdrop').classList.add('active');
}

function selectDate(el, val) {
  document.querySelectorAll('.date-chip').forEach(c=>c.classList.remove('selected'));
  el.classList.add('selected'); selectedDate = val; checkStep1();
}
function selectTime(el, val) {
  document.querySelectorAll('.time-chip').forEach(c=>c.classList.remove('selected'));
  el.classList.add('selected'); selectedTime = val; checkStep1();
}
function checkStep1() {
  document.getElementById('step1Btn').disabled = !(selectedDate && selectedTime);
}

function buildSeatMap() {
  const rows=['A','B','C','D','E','F','G'];
  const taken=[[0,2],[0,3],[1,5],[1,6],[2,1],[3,4],[3,7],[3,8],[4,0],[4,9],[5,2],[5,3],[5,4],[6,6],[6,7]];
  const premium=[0,1];
  const grid=document.getElementById('seatGrid');
  grid.innerHTML='';
  rows.forEach((row,ri)=>{
    const rowDiv=document.createElement('div');
    rowDiv.className='seat-row';
    rowDiv.innerHTML=`<div class="seat-row-label">${row}</div>`;
    for(let si=0;si<10;si++){
      if(si===4){const g=document.createElement('div');g.className='seat-gap';rowDiv.appendChild(g);}
      const isTaken=taken.some(t=>t[0]===ri&&t[1]===si);
      const isPrem=premium.includes(ri);
      const seat=document.createElement('div');
      seat.className=`seat ${isTaken?'taken':'available'} ${isPrem?'premium':''}`;
      seat.dataset.id=`${row}${si+1}`;
      seat.dataset.price=isPrem?Math.round(bookingData.price*1.5):bookingData.price;
      if(!isTaken) seat.onclick=()=>toggleSeat(seat);
      rowDiv.appendChild(seat);
    }
    grid.appendChild(rowDiv);
  });
  selectedSeats=[];
  updateSeatSummary();
}

function toggleSeat(seat){
  const id=seat.dataset.id;
  if(seat.classList.contains('selected')){
    seat.classList.remove('selected');
    selectedSeats=selectedSeats.filter(s=>s!==id);
  } else {
    if(selectedSeats.length>=6){showToast('Max 6 seats per booking bestie 😅');return;}
    seat.classList.add('selected');
    selectedSeats.push(id);
  }
  updateSeatSummary();
}

function updateSeatSummary(){
  const total=selectedSeats.reduce((sum,id)=>{
    const s=document.querySelector(`[data-id="${id}"]`);
    return sum+(s?parseInt(s.dataset.price):0);
  },0);
  document.getElementById('seatSummaryText').textContent=selectedSeats.length?`${selectedSeats.length} seat${selectedSeats.length>1?'s':''} selected`:'No seats selected';
  document.getElementById('seatSummaryNames').textContent=selectedSeats.join(', ');
  document.getElementById('priceDisplay').innerHTML=`₹${total.toLocaleString('en-IN')} <span>total</span>`;
  document.getElementById('step2Btn').disabled=selectedSeats.length===0;
}

function goToStep(n, reset){
  [1,2,3,'Success'].forEach(s=>{
    const el=document.getElementById(`step${s}`);
    if(el) el.classList.toggle('active', s===n);
  });
  [0,1,2].forEach(i=>{
    const dot=document.getElementById(`dot${i}`);
    dot.classList.toggle('active',i===n-1);
    dot.classList.toggle('done',i<n-1);
  });
  if(n===2&&!reset) buildSeatMap();
  if(n===3) buildConfirm();
}

function buildConfirm(){
  const total=selectedSeats.reduce((sum,id)=>{
    const s=document.querySelector(`[data-id="${id}"]`);
    return sum+(s?parseInt(s.dataset.price):0);
  },0);
  document.getElementById('confirmTicket').innerHTML=`
    <div class="ticket-row"><span class="ticket-label">🎬 Movie</span><span class="ticket-val">${bookingData.title}</span></div>
    <div class="ticket-row"><span class="ticket-label">📅 Date & Time</span><span class="ticket-val">${selectedDate}, ${selectedTime}</span></div>
    <div class="ticket-row"><span class="ticket-label">💺 Seats</span><span class="ticket-val">${selectedSeats.join(', ')}</span></div>
    <div class="ticket-row" style="border-top:1px dashed rgba(200,245,62,0.15);padding-top:0.6rem;margin-top:0.4rem">
      <span class="ticket-label">💰 Total</span>
      <span class="ticket-val" style="color:var(--lime);font-size:1.1rem">₹${total.toLocaleString('en-IN')}</span>
    </div>`;
}

function confirmBooking(){
  const total=selectedSeats.reduce((sum,id)=>{
    const s=document.querySelector(`[data-id="${id}"]`);
    return sum+(s?parseInt(s.dataset.price):0);
  },0);
  document.getElementById('successTicket').innerHTML=`
    <div class="ticket-row"><span class="ticket-label">🎬 Movie</span><span class="ticket-val">${bookingData.title}</span></div>
    <div class="ticket-row"><span class="ticket-label">📅 When</span><span class="ticket-val">${selectedDate} · ${selectedTime}</span></div>
    <div class="ticket-row"><span class="ticket-label">💺 Seats</span><span class="ticket-val">${selectedSeats.join(', ')}</span></div>
    <div class="ticket-row"><span class="ticket-label">🎫 Booking ID</span><span class="ticket-val" style="color:var(--cyan)">FZ-${Math.random().toString(36).substr(2,8).toUpperCase()}</span></div>`;
  [1,2,3].forEach(s=>document.getElementById(`step${s}`).classList.remove('active'));
  document.getElementById('stepSuccess').classList.add('active');
  document.getElementById('progressDots').style.display='none';
  document.getElementById('modalHeader').style.display='none';
}

function closeModal(){
  document.getElementById('modalBackdrop').classList.remove('active');
}
function closeOnBackdrop(e){
  if(e.target===document.getElementById('modalBackdrop')) closeModal();
}

/* ═══════════════════════════════════
   SEARCH
═══════════════════════════════════ */
function handleSearch(){
  const val=document.getElementById('searchInput').value.trim().toLowerCase();
  if(!val) return;
  const match=movies.find(m=>m.title.toLowerCase().includes(val)||m.genre.toLowerCase().includes(val));
  if(match){ openBooking(match); }
  else { showToast(`No results for "${val}" bestie 😬`); }
}
document.getElementById('searchInput').addEventListener('keydown',e=>{if(e.key==='Enter')handleSearch();});

/* ═══════════════════════════════════
   TOAST
═══════════════════════════════════ */
function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3000);
}

