let activeAuthTab = 'login';
function switchAuthTab(tab) {
  activeAuthTab = tab;
  document.querySelectorAll('.auth-tab').forEach((t, i) => t.classList.toggle('active', (i===0&&tab==='login')||(i===1&&tab==='signup')));
  document.getElementById('form-login').classList.toggle('active', tab==='login');
  document.getElementById('form-signup').classList.toggle('active', tab==='signup');
}

function handleAuth(type) {
  if (type === 'login') {
    const email = document.getElementById('loginEmail').value.trim();
    const pass = document.getElementById('loginPass').value.trim();
    if (!email || !pass) { showToast('Fill in all fields bestie 👀'); return; }
    if (!email.includes('@')) { showToast('That doesn\'t look like an email lol'); return; }
    showAuthSuccess('WELCOME BACK 👋', `Logged in as ${email}. You're in bestie!`);
  } else {
    const name = document.getElementById('signupName').value.trim();
    const email = document.getElementById('signupEmail').value.trim();
    const pass = document.getElementById('signupPass').value.trim();
    if (!name || !email || !pass) { showToast('Fill in all fields bestie 👀'); return; }
    if (!email.includes('@')) { showToast('That doesn\'t look like an email lol'); return; }
    if (pass.length < 6) { showToast('Password too short bestie, be safer 🔐'); return; }
    showAuthSuccess('ACCOUNT CREATED 🎉', `Welcome to FLICK.ZIP, ${name}! ur one of us now.`);
  }
}

function handleSocialAuth(provider) {
  showAuthSuccess(`SIGNED IN WITH ${provider.toUpperCase()} 🎉`, `You\'re in via ${provider}. Let\'s gooooo!`);
}

